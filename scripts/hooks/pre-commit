#!/usr/bin/env bash
# ryu_ldn_nx pre-commit hook
# Enforces: unit tests pass + per-file coverage >= 80%
# All checks run inside the Docker test container (devkitpro/devkita64).
# Install: python3 scripts/hooks/install.py
#          or: cp scripts/hooks/pre-commit .git/hooks/pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

MIN_COVERAGE="${MIN_COVERAGE:-80}"

echo "=== Pre-commit: running unit tests with coverage in Docker ==="
docker compose run --rm test

echo ""
echo "=== Pre-commit: checking coverage >= ${MIN_COVERAGE}% ==="
docker compose run --rm --entrypoint python3 test /workspace/scripts/check-coverage.py --min "$MIN_COVERAGE" --root /workspace

echo ""
echo "=== Pre-commit: all checks passed ==="
